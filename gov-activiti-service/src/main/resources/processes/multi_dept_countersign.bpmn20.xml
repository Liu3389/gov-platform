<?xml version="1.0" encoding="UTF-8"?>
<definitions
    xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:activiti="http://activiti.org/bpmn"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    targetNamespace="http://www.activiti.org/test">

  <!--
    多部门会签流程 v1
    流程Key：apply_countersign_v1（对应 WorkflowConstants.PROCESS_MULTI_DEPT）
    流程变量参考：WorkflowConstants
      - applyNo：办件号
      - userId：申请人ID
      - itemId：事项ID
      - deptId：部门ID
      - deptList：会签部门列表
      - deptLeader：会签部门领导
      - allApproved：是否全部通过
      - approvalResult：审批结果（1通过 2驳回）
      - approvalOpinion：审批意见
  -->
  <process id="apply_countersign_v1" name="多部门会签流程" isExecutable="true">

    <startEvent id="start_apply" name="开始" />

    <userTask id="task_accept_window" name="窗口受理"
        activiti:candidateGroups="window_staff">
      <extensionElements>
        <activiti:taskListener event="create" class="com.gov.activiti.listener.TaskCreateListener" />
        <activiti:taskListener event="complete" class="com.gov.activiti.listener.TaskCompleteListener" />
      </extensionElements>
    </userTask>

    <userTask id="task_review_dept" name="部门初审"
        activiti:candidateGroups="dept_staff">
      <extensionElements>
        <activiti:taskListener event="create" class="com.gov.activiti.listener.TaskCreateListener" />
        <activiti:taskListener event="complete" class="com.gov.activiti.listener.TaskCompleteListener" />
      </extensionElements>
    </userTask>

    <exclusiveGateway id="gateway_review_result" name="初审结果" />

    <userTask id="task_countersign_multi" name="多部门会签"
        activiti:candidateGroups="multi_dept">
      <extensionElements>
        <activiti:taskListener event="create" class="com.gov.activiti.listener.TaskCreateListener" />
        <activiti:taskListener event="complete" class="com.gov.activiti.listener.TaskCompleteListener" />
      </extensionElements>
    </userTask>

    <exclusiveGateway id="gateway_countersign_result" name="会签结果" />

    <userTask id="task_complete" name="办结"
        activiti:assignee="${applyUserId}">
      <extensionElements>
        <activiti:taskListener event="create" class="com.gov.activiti.listener.TaskCreateListener" />
        <activiti:taskListener event="complete" class="com.gov.activiti.listener.TaskCompleteListener" />
      </extensionElements>
    </userTask>

    <userTask id="task_return_user" name="退回申请人"
        activiti:assignee="${applyUserId}">
      <extensionElements>
        <activiti:taskListener event="create" class="com.gov.activiti.listener.TaskCreateListener" />
        <activiti:taskListener event="complete" class="com.gov.activiti.listener.TaskCompleteListener" />
      </extensionElements>
    </userTask>

    <endEvent id="end_apply" name="结束" />

    <!-- 流程连线 -->
    <sequenceFlow id="flow_start_to_accept" sourceRef="start_apply" targetRef="task_accept_window" />
    <sequenceFlow id="flow_accept_to_review" sourceRef="task_accept_window" targetRef="task_review_dept" />
    <sequenceFlow id="flow_review_to_gateway" sourceRef="task_review_dept" targetRef="gateway_review_result" />

    <!-- 初审通过 → 多部门会签 -->
    <sequenceFlow id="flow_review_pass" sourceRef="gateway_review_result" targetRef="task_countersign_multi">
      <conditionExpression xsi:type="tFormalExpression">${approvalResult == 1}</conditionExpression>
    </sequenceFlow>
    <!-- 初审驳回 → 退回申请人 -->
    <sequenceFlow id="flow_review_reject" sourceRef="gateway_review_result" targetRef="task_return_user">
      <conditionExpression xsi:type="tFormalExpression">${approvalResult == 2}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_countersign_to_gateway" sourceRef="task_countersign_multi" targetRef="gateway_countersign_result" />

    <!-- 会签全部通过 → 办结 → 结束 -->
    <sequenceFlow id="flow_countersign_pass" sourceRef="gateway_countersign_result" targetRef="task_complete">
      <conditionExpression xsi:type="tFormalExpression">${allApproved}</conditionExpression>
    </sequenceFlow>
    <!-- 会签有驳回 → 退回申请人 -->
    <sequenceFlow id="flow_countersign_reject" sourceRef="gateway_countersign_result" targetRef="task_return_user">
      <conditionExpression xsi:type="tFormalExpression">${!allApproved}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_complete_to_end" sourceRef="task_complete" targetRef="end_apply" />
    <sequenceFlow id="flow_return_to_end" sourceRef="task_return_user" targetRef="end_apply" />

  </process>

</definitions>
